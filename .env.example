# LIFF (LINE Front-end Framework) ID
# LINE Developers コンソールで作成した LIFF アプリの ID
NEXT_PUBLIC_LIFF_ID=2010028365-2190HKvK

# GAS Web App エンドポイント URL
# https://script.google.com/macros/s/AKfycb.../exec の形式
NEXT_PUBLIC_GAS_WEB_APP_URL=https://example.com

# GAS doPost 認証用 API Key
# GAS Script Properties の LIFF_API_SECRET と完全一致させる
# 生成例: openssl rand -hex 32
NEXT_PUBLIC_GAS_API_KEY=
